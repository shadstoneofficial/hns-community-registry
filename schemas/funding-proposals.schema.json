{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/shadstoneofficial/hns-community-registry/schemas/funding-proposals.schema.json",
  "title": "HNS Community Registry Funding Proposals",
  "type": "object",
  "required": ["schemaVersion", "entries"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "summary", "sourceUrl", "projectDnsUrl", "projectHnsUrl", "projectUrl", "requestedAmount", "currency", "pledgedAmount", "pledgeSourceUrl", "status", "tags", "proposer", "registryLabels", "lastVerified", "notes"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "title": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "sourceUrl": { "type": "string", "minLength": 1 },
          "projectDnsUrl": { "type": "string" },
          "projectHnsUrl": { "type": "string" },
          "projectUrl": { "type": "string" },
          "requestedAmount": { "type": "string" },
          "currency": { "type": "string" },
          "pledgedAmount": { "type": "string" },
          "pledgeSourceUrl": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "funded", "partially-funded", "closed", "withdrawn", "unknown"] },
          "tags": { "type": "array", "items": { "type": "string" } },
          "proposer": {
            "type": "object",
            "required": ["name", "url"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" }
            }
          },
          "registryLabels": { "$ref": "#/$defs/labels" },
          "lastVerified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "notes": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["community-submitted", "self-declared", "maintainer-verified", "source-verified", "signed", "unverified", "stale", "inactive", "flagged", "hns-site"]
      }
    }
  }
}
