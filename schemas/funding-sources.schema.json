{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/shadstoneofficial/hns-community-registry/schemas/funding-sources.schema.json",
  "title": "HNS Community Registry Funding Sources",
  "type": "object",
  "required": ["schemaVersion", "entries"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "dnsUrl", "hnsUrl", "website", "sourceType", "sourceUrl", "topics", "registryLabels", "lastVerified", "notes"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "dnsUrl": { "type": "string", "description": "Normal DNS website URL, usually https://. Leave empty if unavailable." },
          "hnsUrl": { "type": "string", "description": "Handshake-native website URL. Use a single-label HNS hostname, not a dotted DNS hostname. Leave empty if unavailable." },
          "website": { "type": "string" },
          "sourceType": { "type": "string", "enum": ["github-issues", "github-discussions", "rss", "website", "form", "other"] },
          "sourceUrl": { "type": "string", "minLength": 1 },
          "topics": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
          "registryLabels": { "$ref": "#/$defs/labels" },
          "lastVerified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "notes": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "labels": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["community-submitted", "self-declared", "maintainer-verified", "source-verified", "signed", "unverified", "stale", "inactive", "flagged", "hns-site"]
      }
    }
  }
}
